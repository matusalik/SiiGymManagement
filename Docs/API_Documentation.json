            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Memberships"
        ],
        "summary": "Create a new membership plan",
        "description": "Defines a new membership tier (e.g., Gold, Silver) with a specific price and currency.",
        "operationId": "addMembership",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MembershipRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Membership plan created successfully",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/MembershipResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid plan details or unsupported currency",
