    "/api/member/deactivate/{id}": {
      "patch": {
        "tags": [
          "Members"
        ],
        "summary": "Deactivate membership",
        "description": "Sets the member's status to INACTIVE. Use this when a member cancels or pauses their plan.",
        "operationId": "deactivateMember",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Membership successfully deactivated"
          },
          "404": {
            "description": "Member not found"
          },
          "409": {
            "description": "Conflict: Member is already INACTIVE"
          }
        }
      }
    },
