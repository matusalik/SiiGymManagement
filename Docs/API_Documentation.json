            }
          }
        ],
        "responses": {
          "200": {
            "description": "Membership successfully activated"
          },
          "404": {
            "description": "Member not found"
          },
          "409": {
            "description": "Conflict: Member is already ACTIVE"
          }
        }
      }
    },
